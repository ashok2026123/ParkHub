rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUserOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    function isOwner() {
      return isAuthenticated() && getUserRole() == 'owner';
    }

    // 1. Users Collection rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isUserOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Parking Locations rules
    match /parking_locations/{locationId} {
      allow read: if true; // Public listings visibility
      allow create: if isOwner() || isAdmin();
      allow update: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // 3. Parking Slots rules
    match /parking_slots/{slotId} {
      allow read: if true;
      allow write: if isAdmin() || (isOwner() && get(/databases/$(database)/documents/parking_locations/$(resource.data.locationId)).data.ownerId == request.auth.uid);
    }

    // 4. Bookings Collection rules
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isOwner());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin() || isOwner());
      allow delete: if isAdmin();
    }

    // 5. Payments rules
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin(); // Transactions cannot be modified by users/owners
    }

    // 6. Reviews rules
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 7. Notifications rules
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() || isAdmin();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
